    curriculum_total_frames: int = CURRICULUM_TOTAL_FRAMES
    max_consecutive_successes: int = MAX_CONSECUTIVE_SUCCESSES
    success_steps: int = SUCCESS_STEPS
    keypoint_scale: float = KEYPOINT_SCALE
