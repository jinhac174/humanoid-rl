        spawn=sim_utils.DomeLightCfg(color=(0.75, 0.75, 0.75), intensity=3000.0),
    )


# --- Env cfg ---
@configclass
class ReorientEnvCfg(DirectRLEnvCfg):
    scene: ReorientSceneCfg = ReorientSceneCfg(
        num_envs=4096,
        env_spacing=3.0,
    )

    sim: sim_utils.SimulationCfg = sim_utils.SimulationCfg(
